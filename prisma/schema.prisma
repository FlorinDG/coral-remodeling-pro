generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  companyName String
  vatNumber   String?
  iban        String?
  logoUrl     String?
  planType    String   @default("FREE")
  peppolId    String?
  driveFolderId String?
  email       String?
  street      String?
  postalCode  String?
  city        String?
  documentLanguage   String?
  commercialName     String?
  bic                String?
  deliveryStreet     String?
  deliveryPostalCode String?
  deliveryCity       String?
  headquartersStreet String?
  headquartersPostalCode String?
  headquartersCity   String?
  directorFirstName  String?
  directorLastName   String?
  brandColor         String?

  // Peppol / E-Invoice.be Integration
  eInvoiceTenantId   String?   // e-invoice.be tenant ID (e.g., tenant_abc123)
  eInvoiceApiKey     String?   // e-invoice.be tenant API key for sending documents
  peppolRegistered   Boolean   @default(false)

  // Document Numbering Patterns
  invoicePrefix      String?  @default("INV")
  invoiceConnector   String?  @default("-")
  invoiceDateFormat  String?  @default("YYYY")
  invoiceNumberWidth Int?     @default(3)
  invoiceNextNumber  Int?     @default(1)

  quotationPrefix      String?  @default("OFF")
  quotationConnector   String?  @default("-")
  quotationDateFormat  String?  @default("YYYY")
  quotationNumberWidth Int?     @default(3)
  quotationNextNumber  Int?     @default(1)

  // Document Template
  documentTemplate   String?  @default("t1")
  documentMode       String?  @default("dynamic")  // "dynamic" | "stationery"
  stationeryUrl      String?  // Base64 data URL of uploaded A4 stationery image (PNG/JPG)

  // Phase 2: SaaS Overarching Subscription Controls
  subscriptionStatus String   @default("ACTIVE") // ACTIVE, INACTIVE, TRIAL
  activeModules      String[] @default(["CRM", "PROJECTS", "INVOICING", "CALENDAR", "DATABASES"])

  // OCR Engine — superadmin-configurable per tenant
  // Supported values: GPT4O (default), MINDEE, VERYFI
  ocrEngine          String   @default("GPT4O")

  // Scan quota — monthly limit, reset automatically
  scanCount          Int      @default(0)
  scanQuota          Int      @default(30)   // FREE tier default; PRO=300, ENTERPRISE=-1 (unlimited)
  scanCountResetAt   DateTime @default(now())

  // Per-tenant locked database IDs
  // { invoices: 'db-invoices-<tenantId8>', clients: 'db-clients-<tenantId8>', ... }
  // Empty {} for legacy tenants — they fall back to bare IDs ('db-invoices' etc.)
  lockedDbIds        Json     @default("{}")

  // Peppol monthly usage counters (reset on 1st of each calendar month)
  peppolSentThisMonth      Int      @default(0)
  peppolReceivedThisMonth  Int      @default(0)
  peppolCounterResetAt     DateTime @default(now())

  // ── Phase 2: Stripe Billing Integration ─────────────────────────────
  stripeCustomerId         String?  @unique
  stripeSubscriptionId     String?
  stripePriceId            String?

  // Trial management
  trialEndsAt              DateTime?
  trialNotifiedAt          DateTime?  // when the 7-day reminder was sent

  // Cancellation
  cancellationRequestedAt  DateTime?
  cancellationEffectiveAt  DateTime?
  cancellationNoticeMonths Int?       // 1 for PRO, 2 for ENTERPRISE

  // Per-seat billing (source of truth, synced to Stripe quantities)
  extraUserCount           Int      @default(0)
  workforceUserCount       Int      @default(0)

  // Billing cycle preference
  billingCycle             String   @default("MONTHLY") // MONTHLY, QUARTERLY
  billingStartedAt         DateTime?                    // for fidelity bonus calc (10% after Y1)

  // ── Module Settings ──────────────────────────────────────────────────
  // Financials
  defaultVatRate         Int?     @default(21)         // 21, 12, 6, 0
  vatCalcMode            String?  @default("lines")    // "lines" | "total"
  defaultPaymentTermDays Int?     @default(30)         // payment due days

  // Calendar
  defaultEventDuration   Int?     @default(60)         // minutes
  defaultCalendarView    String?  @default("month")    // "month" | "week" | "day"

  // HR
  workHoursPerDay        Float?   @default(8.0)

  // Projects
  bordereauPrefix        String?  @default("BOR")
  poPrefix               String?  @default("PO")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users                 User[]
  leads                 Lead[]
  bookings              Booking[]
  clientPortals         ClientPortal[]
  events                Event[]
  siteContents          SiteContent[]
  cmsServices           CMS_Service[]
  cmsProjects           CMS_Project[]
  promotionalBanners    PromotionalBanner[]
  notionConnections     NotionConnection[]
  connectedEmailAccounts ConnectedEmailAccount[]
  contacts              Contact[]
  invoices              Invoice[]
  quotations            Quotation[]
  employees             Employee[]
  internalProjects      InternalProject[]
  suppliers             Supplier[]
  globalDatabases       GlobalDatabase[]
}

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name      String
  email     String
  phone     String?
  service   String
  message   String?
  status    String   @default("NEW")
  driveFolderId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientName  String
  clientEmail String
  serviceType String
  date        DateTime
  timeSlot    String
  message     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientPortal {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientName   String
  clientEmail  String
  slug         String          @unique
  password     String? // Hashed password for portal access
  status       String          @default("ACTIVE")
  driveFolderId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  projectTitle String?
  budget       Float?          @default(0)
  paidAmount   Float?          @default(0)
  serviceId    String?
  service      CMS_Service?    @relation(fields: [serviceId], references: [id])
  documents    Document[]
  messages     Message[]
  media        ProjectMedia[]
  updates      ProjectUpdate[]
  tasks        Task[]
}

model ProjectUpdate {
  id        String       @id @default(cuid())
  portalId  String
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Task {
  id        String       @id @default(cuid())
  portalId  String
  eventId   String? // Optional reference to a calendar event
  title     String
  status    String       @default("TODO")
  dueDate   DateTime?
  fileUrl   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  event     Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Event {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title            String
  start            DateTime
  end              DateTime
  allDay           Boolean  @default(false)
  description      String?
  location         String?
  userId           String // Owner of the event
  taskId           String?  @unique // Optional related task
  googleEventId    String?  @unique // ID of corresponding Google Calendar Event
  googleCalendarId String? // ID of the Google Calendar this belongs to
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task[] 
}

model Document {
  id        String       @id @default(cuid())
  portalId  String
  name      String
  url       String
  type      String
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model ProjectMedia {
  id        String       @id @default(cuid())
  portalId  String
  url       String
  caption   String?
  type      String       @default("IMAGE")
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Message {
  id        String       @id @default(cuid())
  portalId  String
  content   String
  sender    String
  replyToId String?
  fileUrl   String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  replyTo   Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]    @relation("MessageReplies")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("TENANT_ADMIN") // SUPERADMIN, TENANT_ADMIN, EMPLOYEE
  environmentLanguage String? @default("en")
  verificationToken   String?
  verificationSentAt  DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?

  // ── Per-module access control (RBAC) ─────────────────────────────────
  // Shape: { "INVOICING": "OWN", "CRM": "ALL", "PROJECTS": "NONE", ... }
  // Absent key defaults to "OWN". Values: ALL | OWN | ASSIGNED_AND_OWN | NONE
  moduleAccess    Json     @default("{}")

  // ── Invitation tracking ──────────────────────────────────────────────
  invitedBy       String?       // userId of the inviter
  invitedAt       DateTime?
  inviteAccepted  Boolean  @default(false)
  inviteToken     String?  @unique  // one-time accept token

  accounts      Account[]
  sessions      Session[]
  events        Event[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SiteContent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key       String
  valueEn   String
  valueNl   String?
  valueFr   String?
  valueRo   String?
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
}

model CMS_Service {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  slug              String         @unique
  titleEn           String
  titleNl           String?
  titleFr           String?
  titleRo           String?
  subtitleEn        String?
  subtitleNl        String?
  subtitleFr        String?
  subtitleRo        String?
  descriptionEn     String
  descriptionNl     String?
  descriptionFr     String?
  descriptionRo     String?
  fullDescriptionEn String
  fullDescriptionNl String?
  fullDescriptionFr String?
  fullDescriptionRo String?
  image             String
  icon              String
  featuresEn        String[]
  featuresNl        String[]
  featuresFr        String[]
  featuresRo        String[]
  order             Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  portals           ClientPortal[]

  @@unique([tenantId, slug])
}

model CMS_Project {
  id         String             @id @default(cuid())
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  titleEn    String
  titleNl    String?
  titleFr    String?
  titleRo    String?
  locationEn String
  locationNl String?
  locationFr String?
  locationRo String?
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  images     CMS_ProjectImage[]
}

model CMS_ProjectImage {
  id        String      @id @default(cuid())
  projectId String
  url       String
  captionEn String?
  captionNl String?
  captionFr String?
  captionRo String?
  isBefore  Boolean     @default(false)
  order     Int         @default(0)
  project   CMS_Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PromotionalBanner {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  textEn    String
  textNl    String?
  textFr    String?
  textRo    String?
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model NotionConnection {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name             String
  databaseId       String
  token            String? // Optional override for global NOTION_TOKEN
  hiddenProperties String[]      @default([])
  lastSynced       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  entries          NotionEntry[]
}

model NotionEntry {
  id           String           @id @default(cuid())
  notionId     String           @unique
  connectionId String
  data         Json // Stores flattened Notion properties
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  connection   NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model ConnectedEmailAccount {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email     String   @unique
  password  String // Symmetrically encrypted
  imapHost  String
  imapPort  Int      @default(993)
  smtpHost  String
  smtpPort  Int      @default(465)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  email     String   
  phone     String?
  address   String?
  town      String?
  language  String?
  tags      String[] @default([])
  driveFolderId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platformLeads      PlatformLead[]
  salesOpportunities SalesOpportunity[]
}

model PlatformLead {
  id              String   @id @default(cuid())
  externalNr      String?
  contactId       String
  source          String   @default("BOBEX")
  dateIn          DateTime @default(now())
  mailReceivedUrl String?

  mailLead     Boolean @default(false)
  callLead     Boolean @default(false)
  visitPlanned Boolean @default(false)

  status     String  @default("NEW")
  statusNote String?
  location   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model SalesOpportunity {
  id        String   @id @default(cuid())
  contactId String
  source    String   @default("WEBSITE")
  dateIn    DateTime @default(now())

  visitPlanned Boolean @default(false)

  status        String  @default("NEW")
  expectedValue Float?  @default(0)
  statusNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoiceNumber String   
  type          String 
  status        String   @default("DRAFT")
  issueDate     DateTime @default(now())
  dueDate       DateTime

  contactId  String? 
  supplierId String? 
  projectId  String? 

  subtotal Float @default(0)
  vatTotal Float @default(0)
  total    Float @default(0)

  notes String?
  items InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, invoiceNumber])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float 
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Quotation {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  quoteNumber String          @unique
  status      String          @default("DRAFT")
  date        DateTime        @default(now())
  validUntil  DateTime
  contactId   String
  subtotal    Float           @default(0)
  vatTotal    Float           @default(0)
  total       Float           @default(0)
  notes       String?
  items       QuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  total       Float
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Employee {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  email      String    @unique
  phone      String?
  role       String 
  status     String    @default("ACTIVE")
  hourlyCost Float? 
  hireDate   DateTime?

  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeEntry {
  id         String  @id @default(cuid())
  employeeId String
  projectId  String? 
  taskId     String? 

  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int? 

  description String?
  isBillable  Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model InternalProject {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  projectCode String 
  name        String
  status      String @default("PLANNING") 

  clientId      String? 
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  budget Float? @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, projectCode])
}

model Supplier {
  id            String  @id @default(cuid())
  tenantId      String
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyName   String
  vatNumber     String? @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  town          String?
  category      String? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalDatabase {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?
  coverImage  String?
  isTemplate  Boolean @default(false)
  folderId    String?

  properties Json @default("[]")
  views      Json @default("[]")

  pages GlobalPage[]

  activeFilters Json? @default("[]")
  activeSorts   Json? @default("[]")

  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalPage {
  id String @id @default(cuid())

  databaseId String
  database   GlobalDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  coverImage String?
  icon       String?

  properties Json @default("{}")

  order Float?

  blocks Json @default("[]")

  createdBy     String
  lastEditedBy  String
  assignedTo    String[]    // user IDs — for ASSIGNED_AND_OWN access filtering
  driveFolderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
