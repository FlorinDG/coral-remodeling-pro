generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                       String                  @id @default(cuid())
  companyName              String
  vatNumber                String?
  iban                     String?
  logoUrl                  String?
  planType                 String                  @default("FREE")
  peppolId                 String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  driveFolderId            String?
  activeModules            String[]                @default(["INVOICING"])
  subscriptionStatus       String                  @default("ACTIVE")
  city                     String?
  email                    String?
  postalCode               String?
  street                   String?
  bic                      String?
  commercialName           String?
  deliveryCity             String?
  deliveryPostalCode       String?
  deliveryStreet           String?
  directorFirstName        String?
  directorLastName         String?
  headquartersCity         String?
  headquartersPostalCode   String?
  headquartersStreet       String?
  documentLanguage         String?
  brandColor               String?
  documentTemplate         String?                 @default("t1")
  invoiceConnector         String?                 @default("-")
  invoiceDateFormat        String?                 @default("YYYY")
  invoiceNextNumber        Int?                    @default(1)
  invoiceNumberWidth       Int?                    @default(3)
  invoicePrefix            String?                 @default("INV")
  quotationConnector       String?                 @default("-")
  quotationDateFormat      String?                 @default("YYYY")
  quotationNextNumber      Int?                    @default(1)
  quotationNumberWidth     Int?                    @default(3)
  quotationPrefix          String?                 @default("OFF")
  eInvoiceApiKey           String?
  eInvoiceTenantId         String?
  peppolRegistered         Boolean                 @default(false)
  peppolCounterResetAt     DateTime                @default(now())
  peppolReceivedThisMonth  Int                     @default(0)
  peppolSentThisMonth      Int                     @default(0)
  ocrEngine                String                  @default("GPT4O")
  scanCount                Int                     @default(0)
  scanCountResetAt         DateTime                @default(now())
  scanQuota                Int                     @default(30)
  lockedDbIds              Json                    @default("{}")
  documentMode             String?                 @default("dynamic")
  stationeryUrl            String?
  billingCycle             String                  @default("MONTHLY")
  billingStartedAt         DateTime?
  cancellationEffectiveAt  DateTime?
  cancellationNoticeMonths Int?
  cancellationRequestedAt  DateTime?
  extraUserCount           Int                     @default(0)
  stripeCustomerId         String?                 @unique
  stripePriceId            String?
  stripeSubscriptionId     String?
  trialEndsAt              DateTime?
  trialNotifiedAt          DateTime?
  workforceUserCount       Int                     @default(0)
  bordereauPrefix          String?                 @default("BOR")
  defaultCalendarView      String?                 @default("month")
  defaultEventDuration     Int?                    @default(60)
  defaultPaymentTermDays   Int?                    @default(30)
  defaultVatRate           Int?                    @default(21)
  poPrefix                 String?                 @default("PO")
  vatCalcMode              String?                 @default("lines")
  workHoursPerDay          Float?                  @default(8.0)
  peppolOptOut             Boolean                 @default(false)
  mindeeApiKey             String?
  veryfiApiKey             String?
  trialGraceEndsAt         DateTime?
  documentFont             String?                 @default("Helvetica")
  documentFontSize         Int?                    @default(10)
  bookings                 Booking[]
  cmsProjects              CMS_Project[]
  cmsServices              CMS_Service[]
  clientPortals            ClientPortal[]
  clockEntries             ClockEntry[]
  connectedEmailAccounts   ConnectedEmailAccount[]
  contacts                 Contact[]
  employees                Employee[]
  events                   Event[]
  globalDatabases          GlobalDatabase[]
  hrProjects               HrProject[]
  hrTeams                  HrTeam[]
  internalProjects         InternalProject[]
  invoices                 Invoice[]
  leads                    Lead[]
  notionConnections        NotionConnection[]
  promotionalBanners       PromotionalBanner[]
  quotations               Quotation[]
  scheduledShifts          ScheduledShift[]
  shiftTemplates           ShiftTemplate[]
  siteContents             SiteContent[]
  suppliers                Supplier[]
  timeOffRequests          TimeOffRequest[]
  users                    User[]
  userProjectAccesses      UserProjectAccess[]
  workerSchedules          WorkerSchedule[]
}

model Lead {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  email         String
  phone         String?
  service       String
  message       String?
  status        String   @default("NEW")
  driveFolderId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id @default(cuid())
  tenantId    String
  clientName  String
  clientEmail String
  serviceType String
  date        DateTime
  timeSlot    String
  message     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClientPortal {
  id               String          @id @default(cuid())
  tenantId         String
  clientName       String
  clientEmail      String
  slug             String          @unique
  password         String?
  status           String          @default("ACTIVE")
  driveFolderId    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  projectTitle     String?
  budget           Float?          @default(0)
  paidAmount       Float?          @default(0)
  serviceId        String?
  linkedDatabaseId String?         @default("db-1")
  linkedProjectId  String?
  service          CMS_Service?    @relation(fields: [serviceId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents        Document[]
  messages         Message[]
  media            ProjectMedia[]
  updates          ProjectUpdate[]
  tasks            Task[]
}

model ProjectUpdate {
  id        String       @id @default(cuid())
  portalId  String
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Task {
  id        String       @id @default(cuid())
  portalId  String
  eventId   String?
  title     String
  status    String       @default("TODO")
  dueDate   DateTime?
  fileUrl   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  event     Event?       @relation(fields: [eventId], references: [id])
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Event {
  id               String   @id @default(cuid())
  tenantId         String
  title            String
  start            DateTime
  end              DateTime
  allDay           Boolean  @default(false)
  description      String?
  location         String?
  userId           String
  taskId           String?  @unique
  googleEventId    String?  @unique
  googleCalendarId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task[]
}

model Document {
  id        String       @id @default(cuid())
  portalId  String
  name      String
  url       String
  type      String
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model ProjectMedia {
  id        String       @id @default(cuid())
  portalId  String
  url       String
  caption   String?
  type      String       @default("IMAGE")
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Message {
  id        String       @id @default(cuid())
  portalId  String
  content   String
  sender    String
  replyToId String?
  fileUrl   String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  replyTo   Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]    @relation("MessageReplies")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  tenantId             String?
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 String    @default("TENANT_ADMIN")
  environmentLanguage  String?   @default("en")
  verificationSentAt   DateTime?
  verificationToken    String?
  passwordResetExpires DateTime?
  passwordResetToken   String?
  inviteAccepted       Boolean   @default(false)
  inviteToken          String?   @unique
  invitedAt            DateTime?
  invitedBy            String?
  moduleAccess         Json      @default("{}")
  employeeStatus       String?   @default("ACTIVE")
  hireDate             DateTime?
  hourlyCost           Float?
  phone                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  accounts             Account[]
  events               Event[]
  sessions             Session[]
  tenant               Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SiteContent {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  valueEn   String
  valueNl   String?
  valueFr   String?
  valueRo   String?
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model CMS_Service {
  id                String         @id @default(cuid())
  tenantId          String
  slug              String         @unique
  titleEn           String
  titleNl           String?
  titleFr           String?
  titleRo           String?
  subtitleEn        String?
  subtitleNl        String?
  subtitleFr        String?
  subtitleRo        String?
  descriptionEn     String
  descriptionNl     String?
  descriptionFr     String?
  descriptionRo     String?
  fullDescriptionEn String
  fullDescriptionNl String?
  fullDescriptionFr String?
  fullDescriptionRo String?
  image             String
  icon              String
  featuresEn        String[]
  featuresNl        String[]
  featuresRo        String[]
  order             Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  featuresFr        String[]
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portals           ClientPortal[]

  @@unique([tenantId, slug])
}

model CMS_Project {
  id         String             @id @default(cuid())
  tenantId   String
  titleEn    String
  titleNl    String?
  titleFr    String?
  titleRo    String?
  locationEn String
  locationNl String?
  locationFr String?
  locationRo String?
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  images     CMS_ProjectImage[]
}

model CMS_ProjectImage {
  id        String      @id @default(cuid())
  projectId String
  url       String
  captionEn String?
  captionNl String?
  captionFr String?
  captionRo String?
  isBefore  Boolean     @default(false)
  order     Int         @default(0)
  project   CMS_Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PromotionalBanner {
  id        String   @id @default(cuid())
  tenantId  String
  textEn    String
  textNl    String?
  textFr    String?
  textRo    String?
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NotionConnection {
  id               String        @id @default(cuid())
  tenantId         String
  name             String
  databaseId       String
  token            String?
  hiddenProperties String[]      @default([])
  lastSynced       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries          NotionEntry[]
}

model NotionEntry {
  id           String           @id @default(cuid())
  notionId     String           @unique
  connectionId String
  data         Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  connection   NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model ConnectedEmailAccount {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  password     String?
  imapHost     String?
  imapPort     Int?      @default(993)
  smtpHost     String?
  smtpPort     Int?      @default(465)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accessToken  String?
  expiresAt    DateTime?
  refreshToken String?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Contact {
  id                 String             @id @default(cuid())
  tenantId           String
  firstName          String
  lastName           String
  email              String
  phone              String?
  address            String?
  town               String?
  tags               String[]           @default([])
  driveFolderId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  language           String?
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformLeads      PlatformLead[]
  salesOpportunities SalesOpportunity[]
}

model PlatformLead {
  id              String   @id @default(cuid())
  externalNr      String?
  contactId       String
  source          String   @default("BOBEX")
  dateIn          DateTime @default(now())
  mailReceivedUrl String?
  mailLead        Boolean  @default(false)
  callLead        Boolean  @default(false)
  visitPlanned    Boolean  @default(false)
  status          String   @default("NEW")
  statusNote      String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model SalesOpportunity {
  id            String   @id @default(cuid())
  contactId     String
  source        String   @default("WEBSITE")
  dateIn        DateTime @default(now())
  visitPlanned  Boolean  @default(false)
  status        String   @default("NEW")
  expectedValue Float?   @default(0)
  statusNote    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String        @id @default(cuid())
  tenantId         String
  invoiceNumber    String
  type             String
  status           String        @default("DRAFT")
  issueDate        DateTime      @default(now())
  dueDate          DateTime
  contactId        String?
  supplierId       String?
  projectId        String?
  subtotal         Float         @default(0)
  vatTotal         Float         @default(0)
  total            Float         @default(0)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  isLocked         Boolean       @default(false)
  parentInvoiceId  String?
  peppolDocumentId String?
  peppolState      String?
  snapshotData     Json?
  parentInvoice    Invoice?      @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes      Invoice[]     @relation("CreditNotes")
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items            InvoiceItem[]

  @@unique([tenantId, invoiceNumber])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Quotation {
  id          String          @id @default(cuid())
  tenantId    String
  quoteNumber String          @unique
  status      String          @default("DRAFT")
  date        DateTime        @default(now())
  validUntil  DateTime
  contactId   String
  subtotal    Float           @default(0)
  vatTotal    Float           @default(0)
  total       Float           @default(0)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       QuotationItem[]
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  total       Float
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Employee {
  id          String      @id @default(cuid())
  tenantId    String
  firstName   String
  lastName    String
  email       String      @unique
  phone       String?
  role        String
  status      String      @default("ACTIVE")
  hourlyCost  Float?
  hireDate    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
}

model TimeEntry {
  id              String    @id @default(cuid())
  employeeId      String
  projectId       String?
  taskId          String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  description     String?
  isBillable      Boolean   @default(true)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model InternalProject {
  id            String    @id @default(cuid())
  tenantId      String
  projectCode   String
  name          String
  status        String    @default("PLANNING")
  clientId      String?
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?
  budget        Float?    @default(0)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectCode])
}

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  companyName   String
  vatNumber     String?  @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  town          String?
  category      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model GlobalDatabase {
  id            String       @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  icon          String?
  coverImage    String?
  isTemplate    Boolean      @default(false)
  folderId      String?
  properties    Json         @default("[]")
  views         Json         @default("[]")
  activeFilters Json?        @default("[]")
  activeSorts   Json?        @default("[]")
  ownerId       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pages         GlobalPage[]

  @@index([tenantId])
}

model GlobalPage {
  id            String         @id @default(cuid())
  databaseId    String
  coverImage    String?
  icon          String?
  properties    Json           @default("{}")
  order         Float?
  blocks        Json           @default("[]")
  createdBy     String
  lastEditedBy  String
  driveFolderId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assignedTo    String[]
  database      GlobalDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@index([createdAt])
}

model ClockEntry {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  clockInTime       DateTime  @default(now())
  clockOutTime      DateTime?
  clockInLatitude   Float?
  clockInLongitude  Float?
  clockOutLatitude  Float?
  clockOutLongitude Float?
  taskDescription   String?
  requiresApproval  Boolean   @default(false)
  approvalStatus    String?
  approvedBy        String?
  approvedAt        DateTime?
  shiftId           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  noBreak           Boolean   @default(false)
  photos            Json?
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ScheduledShift {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  shiftDate    String
  shiftStart   String
  shiftEnd     String
  shiftName    String?
  projectId    String?
  role         String?
  notes        String?
  status       String   @default("scheduled")
  createdBy    String?
  lastEditedBy String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ShiftTemplate {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  shiftStart String
  shiftEnd   String
  projectId  String?
  role       String?
  notes      String?
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HrTeam {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members     HrTeamMember[]
}

model HrTeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  team      HrTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TimeOffRequest {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  requestType String    @default("vacation")
  startDate   String
  endDate     String
  status      String    @default("pending")
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WorkerSchedule {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  dayOfWeek  Int
  shiftStart String
  shiftEnd   String
  isActive   Boolean  @default(true)
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HrProject {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  color     String   @default("#3b82f6")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  latitude  Float?
  longitude Float?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ShiftTask {
  id          String    @id @default(cuid())
  shiftId     String
  taskId      String
  /// Worker-reported progress status for this shift assignment.
  /// Values: pending | in_progress | done_by_worker
  /// Separate from the db-tasks page status — only management can close the actual task.
  status      String    @default("pending")
  completedBy String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  /// Checklist items added by the worker for this specific shift assignment.
  /// Shape: [{ id, title, done, doneAt?, doneBy? }]
  subtasks    Json?     @default("[]")
  /// Free-text notes from the worker about their progress on this shift task.
  workerNotes String?

  @@index([shiftId])
}

model ShiftAttachment {
  id        String   @id @default(cuid())
  shiftId   String
  name      String
  url       String
  type      String
  size      Int?
  createdAt DateTime @default(now())

  @@index([shiftId])
}

model UserProjectAccess {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  projectId String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([tenantId])
  @@index([userId])
}
