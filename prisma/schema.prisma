generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String
  message   String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id          String   @id @default(cuid())
  clientName  String
  clientEmail String
  serviceType String
  date        DateTime
  timeSlot    String
  message     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientPortal {
  id           String          @id @default(cuid())
  clientName   String
  clientEmail  String
  slug         String          @unique
  password     String? // Hashed password for portal access
  status       String          @default("ACTIVE")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  projectTitle String?
  budget       Float?          @default(0)
  paidAmount   Float?          @default(0)
  serviceId    String?
  service      CMS_Service?    @relation(fields: [serviceId], references: [id])
  documents    Document[]
  messages     Message[]
  media        ProjectMedia[]
  updates      ProjectUpdate[]
  tasks        Task[]
}

model ProjectUpdate {
  id        String       @id @default(cuid())
  portalId  String
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Task {
  id        String       @id @default(cuid())
  portalId  String
  eventId   String? // Optional reference to a calendar event
  title     String
  status    String       @default("TODO")
  dueDate   DateTime?
  fileUrl   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  event     Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Event {
  id               String   @id @default(cuid())
  title            String
  start            DateTime
  end              DateTime
  allDay           Boolean  @default(false)
  description      String?
  location         String?
  userId           String // Owner of the event
  taskId           String?  @unique // Optional related task
  googleEventId    String?  @unique // ID of corresponding Google Calendar Event
  googleCalendarId String? // ID of the Google Calendar this belongs to
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task[] // One-to-many from Event to Task (though typically 1:1 in this usecase, prisma needs array or unique back relation. The Task side has eventId and a relation)
}

model Document {
  id        String       @id @default(cuid())
  portalId  String
  name      String
  url       String
  type      String
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model ProjectMedia {
  id        String       @id @default(cuid())
  portalId  String
  url       String
  caption   String?
  type      String       @default("IMAGE")
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
}

model Message {
  id        String       @id @default(cuid())
  portalId  String
  content   String
  sender    String
  replyToId String?
  fileUrl   String?
  createdAt DateTime     @default(now())
  portal    ClientPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  replyTo   Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]    @relation("MessageReplies")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("ADMIN")
  accounts      Account[]
  sessions      Session[]
  events        Event[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  valueEn   String
  valueNl   String?
  valueFr   String?
  valueRo   String?
  updatedAt DateTime @updatedAt
}

model CMS_Service {
  id                String         @id @default(cuid())
  slug              String         @unique
  titleEn           String
  titleNl           String?
  titleFr           String?
  titleRo           String?
  subtitleEn        String?
  subtitleNl        String?
  subtitleFr        String?
  subtitleRo        String?
  descriptionEn     String
  descriptionNl     String?
  descriptionFr     String?
  descriptionRo     String?
  fullDescriptionEn String
  fullDescriptionNl String?
  fullDescriptionFr String?
  fullDescriptionRo String?
  image             String
  icon              String
  featuresEn        String[]
  featuresNl        String[]
  featuresFr        String[]
  featuresRo        String[]
  order             Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  portals           ClientPortal[]
}

model CMS_Project {
  id         String             @id @default(cuid())
  titleEn    String
  titleNl    String?
  titleFr    String?
  titleRo    String?
  locationEn String
  locationNl String?
  locationFr String?
  locationRo String?
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  images     CMS_ProjectImage[]
}

model CMS_ProjectImage {
  id        String      @id @default(cuid())
  projectId String
  url       String
  captionEn String?
  captionNl String?
  captionFr String?
  captionRo String?
  isBefore  Boolean     @default(false)
  order     Int         @default(0)
  project   CMS_Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PromotionalBanner {
  id        String   @id @default(cuid())
  textEn    String
  textNl    String?
  textFr    String?
  textRo    String?
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model NotionConnection {
  id               String        @id @default(cuid())
  name             String
  databaseId       String
  token            String? // Optional override for global NOTION_TOKEN
  hiddenProperties String[]      @default([])
  lastSynced       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  entries          NotionEntry[]
}

model NotionEntry {
  id           String           @id @default(cuid())
  notionId     String           @unique
  connectionId String
  data         Json // Stores flattened Notion properties
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  connection   NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model ConnectedEmailAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // In a production environment, this should be symmetrically encrypted
  imapHost  String
  imapPort  Int      @default(993)
  smtpHost  String
  smtpPort  Int      @default(465)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  address   String?
  town      String?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platformLeads      PlatformLead[]
  salesOpportunities SalesOpportunity[]
}

model PlatformLead {
  id              String   @id @default(cuid())
  externalNr      String?
  contactId       String
  source          String   @default("BOBEX")
  dateIn          DateTime @default(now())
  mailReceivedUrl String?

  mailLead     Boolean @default(false)
  callLead     Boolean @default(false)
  visitPlanned Boolean @default(false)

  status     String  @default("NEW")
  statusNote String?
  location   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model SalesOpportunity {
  id        String   @id @default(cuid())
  contactId String
  source    String   @default("WEBSITE")
  dateIn    DateTime @default(now())

  visitPlanned Boolean @default(false)

  status        String  @default("NEW")
  expectedValue Float?  @default(0)
  statusNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// =========================================================================================
// NEW GLOBAL MODULES (HR, FINANCIALS, PROJECTS, SUPPLIERS)
// =========================================================================================

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique // e.g., "INV-2026-001"
  type          String // "SALES", "PURCHASE", "CREDIT_NOTE_SALES", "CREDIT_NOTE_PURCHASE"
  status        String   @default("DRAFT") // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED
  issueDate     DateTime @default(now())
  dueDate       DateTime

  // Relations
  contactId  String? // For Sales/Clients
  supplierId String? // For Purchases
  projectId  String? // Optional linkage to an Internal Project

  // Totals
  subtotal Float @default(0)
  vatTotal Float @default(0)
  total    Float @default(0)

  notes String?
  items InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float // e.g., 6, 21 for Belgium
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Quotation {
  id          String          @id @default(cuid())
  quoteNumber String          @unique // e.g., "OFF-2026-001"
  status      String          @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  date        DateTime        @default(now())
  validUntil  DateTime
  contactId   String
  subtotal    Float           @default(0)
  vatTotal    Float           @default(0)
  total       Float           @default(0)
  notes       String?
  items       QuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  total       Float
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Employee {
  id         String    @id @default(cuid())
  firstName  String
  lastName   String
  email      String    @unique
  phone      String?
  role       String // e.g., "MANAGER", "CONTRACTOR", "TECHNICIAN"
  status     String    @default("ACTIVE")
  hourlyCost Float? // Internal cost calculation
  hireDate   DateTime?

  timeEntries TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeEntry {
  id         String  @id @default(cuid())
  employeeId String
  projectId  String? // Link to Internal Project where time was spent
  taskId     String? // Optional specific task

  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int? // Calculated upon clock-out

  description String?
  isBillable  Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model InternalProject {
  id          String @id @default(cuid())
  projectCode String @unique // e.g., "PRJ-014"
  name        String
  status      String @default("PLANNING") // PLANNING, ACTIVE, ON_HOLD, COMPLETED, CANCELLED

  clientId      String? // Maps to Contact
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  budget Float? @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id            String  @id @default(cuid())
  companyName   String
  vatNumber     String? @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  town          String?
  category      String? // e.g., "MATERIALS", "SUBCONTRACTOR", "LOGISTICS"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Global Databases Ecosystem (Notion-Style Grids) ---

model GlobalDatabase {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?
  coverImage  String?
  isTemplate  Boolean @default(false)
  folderId    String?

  // JSON arrays of Property[] and DatabaseView[]
  properties Json @default("[]")
  views      Json @default("[]")

  pages GlobalPage[]

  // Legacy fallback configs
  activeFilters Json? @default("[]")
  activeSorts   Json? @default("[]")

  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalPage {
  id String @id @default(cuid())

  databaseId String
  database   GlobalDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  coverImage String?
  icon       String?

  // Record<PropertyId, PropertyValue>
  properties Json @default("{}")

  order Float?

  // Array of Block[] representing subcomponents/rich text
  blocks Json @default("[]")

  createdBy     String
  lastEditedBy  String
  driveFolderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
